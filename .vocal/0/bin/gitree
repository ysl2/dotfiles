#!/usr/bin/env python3

import subprocess
from pathlib import Path
from typing import Dict, List, Tuple


# --- Constants for colored output ---
class Colors:
    """ANSI color codes for terminal output."""

    BLUE = '\033[34m'
    CYAN = '\033[36m'
    RED = '\033[31m'
    RESET = '\033[0m'


# --- Core Data Structure ---
class Node:
    """Represents a file or directory in the tree."""

    def __init__(self, name: str, node_type: str = 'blob'):
        self.name = name
        # 'tree' (directory), 'blob' (file), 'symlink', or 'commit' (submodule)
        self.node_type = node_type
        self.children: Dict[str, Node] = {}


# --- Main Tree Class ---
class GitTree:
    """Builds and displays a tree of files from a Git repository."""

    def __init__(
        self,
        repo_root: Path,
        symlink_targets: Dict[str, str],
    ):
        self.repo_root = repo_root
        self.root = Node(repo_root.name, node_type='tree')
        self.symlink_targets = symlink_targets

    def add_path(self, path: str, node_type: str):
        """Adds a path to the tree using pathlib for path splitting."""
        current = self.root
        # Use pathlib's parts attribute for robust path splitting
        parts = Path(path).parts

        for part in parts[:-1]:
            if part not in current.children:
                current.children[part] = Node(part, node_type='tree')
            current = current.children[part]

        final_part = parts[-1]
        if final_part:
            current.children[final_part] = Node(final_part, node_type)

    def _format_symlink_target(self, link_path: str, target_link: str) -> str:
        """Formats symlink target by checking working tree filesystem state."""
        link_fs_path = self.repo_root / Path(*Path(link_path).parts)
        if Path(target_link).is_absolute():
            target_fs_path = Path(target_link)
        else:
            target_fs_path = (link_fs_path.parent / target_link).resolve()

        if not target_fs_path.exists():
            return f'{Colors.RED}{target_link}{Colors.RESET}'
        if target_fs_path.is_dir():
            return f'{Colors.BLUE}{target_link}{Colors.RESET}/'
        return target_link

    def _get_display_name(self, node: Node, git_path: str) -> str:
        """
        Formats the node name with colors and symlink info.
        NOTE: This version checks Git object data, not working tree files.
        """
        if node.node_type == 'symlink':
            target_link = self.symlink_targets.get(git_path)
            if target_link is None:
                target_str = f'{Colors.RED}? (missing git object){Colors.RESET}'
            else:
                target_str = self._format_symlink_target(git_path, target_link)
            return f'{Colors.CYAN}{node.name}{Colors.RESET} -> {target_str}'

        if node.node_type == 'tree':
            return f'{Colors.BLUE}{node.name}{Colors.RESET}/'

        return node.name  # For 'blob' and 'commit' types

    def _print_recursive(self, node: Node, prefix: str, current_path: str):
        """Recursively prints the tree nodes with proper indentation."""
        children = sorted(node.children.values(), key=lambda n: (n.node_type != 'tree', n.name))

        for i, child in enumerate(children):
            is_last = i == len(children) - 1
            connector = '└── ' if is_last else '├── '
            child_path = f'{current_path}/{child.name}' if current_path else child.name

            display_name = self._get_display_name(child, child_path)
            print(f'{prefix}{connector}{display_name}')

            new_prefix = prefix + ('    ' if is_last else '│   ')
            self._print_recursive(child, new_prefix, child_path)

    def print_tree(self):
        """Public method to start printing the tree."""
        print(f'{Colors.BLUE}{self.root.name}{Colors.RESET}/')
        self._print_recursive(self.root, '', '')


# --- Git Interaction Functions ---
def get_git_repo_root() -> Path:
    """Finds the root directory of the current Git repository as a Path object."""
    cmd = ['git', 'rev-parse', '--show-toplevel']
    result = subprocess.run(cmd, capture_output=True, text=True, check=True)
    return Path(result.stdout.strip())


def get_git_files(repo_root: Path) -> List[Tuple[str, str, str]]:
    """Retrieves tracked files from git as (path, node_type, object_id)."""
    cmd = ['git', 'ls-tree', '--full-tree', '-r', '-z', 'HEAD']
    process = subprocess.run(cmd, cwd=repo_root, capture_output=True, check=True)

    files = []
    for record in process.stdout.split(b'\0'):
        if not record:
            continue
        metadata, path = record.split(b'\t', 1)
        mode, node_type, object_id = metadata.decode('utf-8', 'surrogateescape').split()
        git_path = path.decode('utf-8', 'surrogateescape')

        if mode == '120000':
            node_type = 'symlink'

        files.append((git_path, node_type, object_id))
    return files


def get_symlink_targets(repo_root: Path, git_files: List[Tuple[str, str, str]]) -> Dict[str, str]:
    """Reads symlink target paths from Git blob objects keyed by symlink path."""
    targets: Dict[str, str] = {}
    for path, node_type, object_id in git_files:
        if node_type != 'symlink':
            continue
        process = subprocess.run(
            ['git', 'cat-file', '-p', object_id],
            cwd=repo_root,
            capture_output=True,
            check=True,
        )
        targets[path] = process.stdout.decode('utf-8', 'surrogateescape').rstrip('\n')
    return targets


# --- Main Execution ---
if __name__ == '__main__':
    try:
        repo_root = get_git_repo_root()
        git_paths = get_git_files(repo_root)
        symlink_targets = get_symlink_targets(repo_root, git_paths)

        path_tree = GitTree(repo_root, symlink_targets)
        for path, node_type, _ in git_paths:
            path_tree.add_path(path, node_type)

        path_tree.print_tree()

    except FileNotFoundError:
        print("Error: 'git' command not found. Is Git installed and in your PATH?")
    except subprocess.CalledProcessError:
        print('Error: This does not appear to be a Git repository, or it has no commits.')
    except Exception as e:
        print(f'An unexpected error occurred: {e}')
